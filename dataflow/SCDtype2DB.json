{
	"name": "SCDtype2DB",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "srcfile",
						"type": "DatasetReference"
					},
					"name": "srcfile"
				},
				{
					"dataset": {
						"referenceName": "trgttable",
						"type": "DatasetReference"
					},
					"name": "tgrttable"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "trgttable",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "srcHASH"
				},
				{
					"name": "trgtHASH"
				},
				{
					"name": "hashnotexists"
				},
				{
					"name": "derivecols"
				},
				{
					"name": "removehash"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "recordexists"
				},
				{
					"name": "hashnotexist"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcfile",
				"source(output(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string,",
				"          is_active as integer,",
				"          start_date as timestamp,",
				"          end_date as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> tgrttable",
				"srcfile derive(hash = md5(emp_id,name,dept,salary,location)) ~> srcHASH",
				"tgrttable derive(hash = md5(emp_id,name,dept,salary,location)) ~> trgtHASH",
				"srcHASH, trgtHASH exists(srcHASH@hash == trgtHASH@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> hashnotexists",
				"hashnotexists derive({start_date } = currentTimestamp(),",
				"          {end_date } = 2999-12-31,",
				"          {is_current } = 1) ~> derivecols",
				"derivecols select(mapColumn(",
				"          emp_id,",
				"          name,",
				"          dept,",
				"          salary,",
				"          location,",
				"          {start_date },",
				"          {end_date },",
				"          {is_current }",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> removehash",
				"removehash alterRow(insertIf(1>0)) ~> alterRow1",
				"trgtHASH, srcHASH exists(tgrttable@emp_id == srcfile@emp_id,",
				"     negate:false,",
				"     broadcast: 'auto')~> recordexists",
				"recordexists, srcHASH exists(trgtHASH@hash == srcHASH@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> hashnotexist",
				"hashnotexist derive(is_active = 0,",
				"          end_date = currentTimestamp()) ~> derivedColumn1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string,",
				"          is_active as integer,",
				"          start_date as timestamp,",
				"          end_date as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}