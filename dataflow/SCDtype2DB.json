{
	"name": "SCDtype2DB",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "srcfile",
						"type": "DatasetReference"
					},
					"name": "srcfile"
				},
				{
					"dataset": {
						"referenceName": "trgttable",
						"type": "DatasetReference"
					},
					"name": "tgrttable"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "stagingsink",
						"type": "DatasetReference"
					},
					"name": "stagingtableinsert"
				},
				{
					"dataset": {
						"referenceName": "stagingsink",
						"type": "DatasetReference"
					},
					"name": "stagingtableupdate"
				}
			],
			"transformations": [
				{
					"name": "srcHASH"
				},
				{
					"name": "trgtHASH"
				},
				{
					"name": "hashnotexists"
				},
				{
					"name": "derivecols"
				},
				{
					"name": "removehash"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "recordexists"
				},
				{
					"name": "hashnotexist"
				},
				{
					"name": "markinactive"
				},
				{
					"name": "hashremove"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "isactive1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     run_id as string",
				"}",
				"source(output(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcfile",
				"source(output(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string,",
				"          is_active as integer,",
				"          start_date as timestamp,",
				"          end_date as timestamp,",
				"          created_date as timestamp,",
				"          updated_date as timestamp,",
				"          pipeline_run_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> tgrttable",
				"srcfile derive(hash = md5(emp_id,name,dept,salary,location)) ~> srcHASH",
				"isactive1 derive(hash = md5(emp_id,name,dept,salary,location)) ~> trgtHASH",
				"srcHASH, trgtHASH exists(srcHASH@hash == trgtHASH@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> hashnotexists",
				"hashnotexists derive({start_date } = currentTimestamp(),",
				"          {end_date } = 9999-12-31,",
				"          is_active = 1,",
				"          {created_date } = currentTimestamp(),",
				"          {updated_date } = currentTimestamp(),",
				"          {pipeline_run_id } = $run_id) ~> derivecols",
				"derivecols select(mapColumn(",
				"          emp_id,",
				"          name,",
				"          dept,",
				"          salary,",
				"          location,",
				"          {start_date },",
				"          {end_date },",
				"          is_active,",
				"          {created_date },",
				"          {updated_date },",
				"          {pipeline_run_id }",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: false) ~> removehash",
				"removehash alterRow(insertIf(1>0)) ~> alterRow1",
				"trgtHASH, srcHASH exists(tgrttable@emp_id == srcfile@emp_id,",
				"     negate:false,",
				"     broadcast: 'auto')~> recordexists",
				"recordexists, srcHASH exists(trgtHASH@hash == srcHASH@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> hashnotexist",
				"hashnotexist derive(is_active = 0,",
				"          end_date = currentTimestamp(),",
				"          updated_date = currentTimestamp(),",
				"          pipeline_run_id = $run_id) ~> markinactive",
				"markinactive select(mapColumn(",
				"          emp_id,",
				"          name,",
				"          dept,",
				"          salary,",
				"          location,",
				"          is_active,",
				"          start_date,",
				"          end_date,",
				"          created_date,",
				"          updated_date,",
				"          pipeline_run_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> hashremove",
				"hashremove alterRow(updateIf(true())) ~> alterRow2",
				"tgrttable filter(is_active ==1) ~> isactive1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     input(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string,",
				"          is_active as integer,",
				"          start_date as timestamp,",
				"          created_date as timestamp,",
				"          updated_date as timestamp,",
				"          pipeline_run_id as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          emp_id,",
				"          name,",
				"          dept,",
				"          salary,",
				"          location,",
				"          is_active",
				"     )) ~> stagingtableinsert",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          emp_id as integer,",
				"          name as string,",
				"          dept as string,",
				"          salary as integer,",
				"          location as string,",
				"          is_active as integer,",
				"          start_date as timestamp,",
				"          created_date as timestamp,",
				"          updated_date as timestamp,",
				"          pipeline_run_id as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> stagingtableupdate"
			]
		}
	}
}