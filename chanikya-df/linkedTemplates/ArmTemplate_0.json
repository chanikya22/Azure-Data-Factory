	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "chanikya-df"
		},
		"linkedserviceDL_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linkedserviceDL'"
		},
		"ls_azureSql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_azureSql'"
		},
		"HttpServer1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/"
		},
		"linkedserviceDL_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://chanikyaadf.dfs.core.windows.net/"
		},
		"ls_azureSql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "chanikyasql.database.windows.net"
		},
		"ls_azureSql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azureProjectserver"
		},
		"ls_azureSql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "chanazureserver"
		},
		"ls_git_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/"
		}
	},
